{% liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign cta_url = section.settings.cta_url
  if cta_url == blank
    assign cta_url = '/collections/iluminacion-decorativa'
  endif
%}

{{ 'luminove-hero-3d.css' | asset_url | stylesheet_tag }}

<div
  id="LuminoveHero3D-{{ section.id }}"
  class="luminove-hero-3d"
  data-luminove-hero-3d
  data-particle-density="{{ section.settings.particle_density }}"
  data-parallax-intensity="{{ section.settings.parallax_intensity }}"
  style="--luminove-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="luminove-hero-3d__layer luminove-hero-3d__layer--bg" data-hero-layer="bg">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2600
        | image_tag:
          widths: '750, 1100, 1500, 2000, 2600',
          sizes: '100vw',
          alt: section.settings.image.alt | default: section.settings.heading,
          class: 'luminove-hero-3d__image',
          fetchpriority: 'high',
          loading: 'eager'
      }}
    {% else %}
      <div class="luminove-hero-3d__image luminove-hero-3d__image--fallback"></div>
    {% endif %}
  </div>

  <div
    class="luminove-hero-3d__layer luminove-hero-3d__layer--glow"
    data-hero-layer="glow"
    aria-hidden="true"
  ></div>

  <div class="luminove-hero-3d__overlay" aria-hidden="true"></div>

  <canvas class="luminove-hero-3d__particles" data-hero-particles aria-hidden="true"></canvas>

  <div class="luminove-hero-3d__layer luminove-hero-3d__layer--content" data-hero-layer="content">
    <div class="luminove-hero-3d__content">
      {% if section.settings.heading != blank %}
        {% if heading_tag == 'h1' %}
          <h1 class="luminove-hero-3d__heading">{{ section.settings.heading }}</h1>
        {% else %}
          <h2 class="luminove-hero-3d__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="luminove-hero-3d__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a href="{{ cta_url }}" class="luminove-hero-3d__cta button">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script src="{{ 'luminove-hero-3d.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Lumi Hero 3D",
  "tag": "section",
  "class": "luminove-hero-3d-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Nivel de título",
      "info": "Usa H1 solo si esta sección es el título principal de la página (evita duplicar el H1).",
      "options": [
        { "value": "h1", "label": "H1 (título principal de la página)" },
        { "value": "h2", "label": "H2 (subtítulo de sección)" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Tu Paraíso de Luz"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Ilumina cada momento con nuestra colección artesanal de iluminación decorativa."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Descubrir la Colección"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace del botón",
      "info": "Si se deja vacío, apunta a /collections/iluminacion-decorativa."
    },
    {
      "type": "header",
      "content": "Imagen de fondo"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidad del degradado",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "header",
      "content": "Efecto 3D"
    },
    {
      "type": "range",
      "id": "parallax_intensity",
      "label": "Intensidad del parallax",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "particle_density",
      "label": "Densidad de partículas (escritorio)",
      "info": "El número real se limita automáticamente a 40 en escritorio y 15 en móvil.",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Lumi Hero 3D",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
